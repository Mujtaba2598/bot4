    }
    
    res.json({
        success: true,
        message: 'Trading stopped successfully'
    });
});

// Get trading updates
app.post('/api/tradingUpdate', async (req, res) => {
    const { sessionId, currentProfit, targetProfit, initialInvestment, timeLimit } = req.body;
    
    if (!database.sessions[sessionId]) {
        return res.status(401).json({
            success: false,
            message: 'Invalid session'
        });
    }
    
    const session = database.sessions[sessionId];
    const botId = session.activeBot;
    
    if (!botId || !database.activeTrades[botId] || !database.activeTrades[botId].isRunning) {
        return res.json({
            success: true,
            isRunning: false,
            currentProfit: currentProfit || 0
        });
    }
    
    const trade = database.activeTrades[botId];
    const newTrades = [];
    
    try {
        // Process up to 3 trading pairs
        const pairsToProcess = trade.tradingPairs.slice(0, 3);
        
        for (const symbol of pairsToProcess) {
            try {
                const ticker = await BinanceAPI.getTicker(symbol, session.apiKey, session.secretKey, session.accountType === 'testnet');
                
                const marketData = {
                    symbol,
                    price: parseFloat(ticker.lastPrice) || 0,
                    volume24h: parseFloat(ticker.volume) || 0,
                    priceChange24h: parseFloat(ticker.priceChangePercent) || 0,
                    high24h: parseFloat(ticker.highPrice) || 0,
                    low24h: parseFloat(ticker.lowPrice) || 0,
                    quoteVolume: parseFloat(ticker.quoteVolume) || 0
                };
                
                const signal = await aiEngine.analyzeMarket(symbol, marketData);
                
                trade.aiDecisions.push({
                    ...signal,
                    timestamp: Date.now()
                });
                
                // Execute trade based on AI signal with 10% probability to avoid too many trades
                if (signal.action !== 'HOLD' && signal.confidence > 0.7 && Math.random() > 0.9) {
                    
                    const riskMultiplier = {
                        low: 0.05,
                        medium: 0.1,
                        high: 0.2
                    }[trade.riskLevel] || 0.1;
                    
                    const timeMultiplier = 1 / (trade.timeLimit || 1);
                    const targetMultiplier = (trade.targetProfit / trade.initialInvestment) / 100;
                    
                    const positionSize = trade.initialInvestment * riskMultiplier * signal.confidence * timeMultiplier * targetMultiplier;
                    
                    if (positionSize >= 5) { // Minimum $5 trade
                        const order = await BinanceAPI.placeMarketOrderQuote(
                            session.apiKey,
                            session.secretKey,
                            symbol,
                            signal.action,
                            positionSize.toFixed(2),
                            session.accountType === 'testnet'
                        );
                        
                        const fillPrice = parseFloat(order.fills?.[0]?.price || marketData.price);
                        const quantity = parseFloat(order.executedQty) || 0;
                        
                        // Simulate profit for demo purposes
                        const simulatedProfit = (Math.random() * 2 - 0.5) * positionSize * 0.1;
                        
                        const scaledProfit = simulatedProfit * (trade.targetProfit / trade.initialInvestment) * 0.01;
                        
                        newTrades.push({
                            symbol,
                            side: signal.action,
                            quantity: quantity || (positionSize / (marketData.price || 1)).toFixed(4),
                            price: fillPrice || marketData.price,
                            profit: scaledProfit,
                            confidence: signal.confidence,
                            aiSignal: signal,
                            orderId: order.orderId || 'sim_' + Date.now(),
                            timestamp: new Date().toISOString()
                        });
                        
                        trade.currentProfit += scaledProfit;
                        
                        console.log(`📈 Trade executed: ${signal.action} $${positionSize.toFixed(2)} ${symbol} - Profit: $${scaledProfit.toFixed(2)}`);
                        
                        aiEngine.updatePerformance({ profit: scaledProfit });
                    }
                }
            } catch (error) {
                console.error(`Error processing ${symbol}:`, error.message);
            }
        }
        
        // Add simulated trades occasionally for demo
        if (newTrades.length === 0 && Math.random() > 0.7) {
            const symbols = trade.tradingPairs;
            const randomSymbol = symbols[Math.floor(Math.random() * symbols.length)];
            const randomProfit = (Math.random() * 3 - 1) * 5;
            
            newTrades.push({
                symbol: randomSymbol,
                side: randomProfit > 0 ? 'BUY' : 'SELL',
                quantity: (Math.random() * 0.1 + 0.01).toFixed(4),
                price: (Math.random() * 10000 + 100).toFixed(2),
                profit: randomProfit,
                confidence: 0.8 + Math.random() * 0.15,
                simulated: true,
                timestamp: new Date().toISOString()
            });
            
            trade.currentProfit += randomProfit;
        }
        
        trade.trades.push(...newTrades);
        trade.lastUpdate = Date.now();
        
        // Limit trades array size
        if (trade.trades.length > 100) {
            trade.trades = trade.trades.slice(-100);
        }
        
        res.json({
            success: true,
            currentProfit: trade.currentProfit || 0,
            newTrades,
            aiStats: {
                totalDecisions: trade.aiDecisions.length,
                avgConfidence: trade.aiDecisions.length > 0 
                    ? trade.aiDecisions.reduce((acc, d) => acc + (d.confidence || 0), 0) / trade.aiDecisions.length 
                    : 0,
                performance: aiEngine.performance
            },
            timestamp: new Date().toISOString()
        });
        
    } catch (error) {
        console.error('Trading update error:', error);
        res.json({
            success: true,
            currentProfit: trade?.currentProfit || 0,
            newTrades: [],
            error: error.message
        });
    }
});

